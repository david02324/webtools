---
// 텍스트 → 슬랙 이모지 화면 본문 — 로케일을 받아 기본/언어별 페이지에서 함께 재사용한다.
// 다른 단독 도구(VideoToWebpView)와 같은 구조: h1 + 한 줄 설명 + 본체 + SEO 구조화 데이터.
import BaseLayout from '../layouts/BaseLayout.astro';
import SlackEmoji from './SlackEmoji.astro';
import { SLACK_EMOJI_SLUG } from '../lib/formats';
import { HTML_LANG, type Locale } from '../i18n/config';
import { UI } from '../i18n/ui';
import { SLACK_EMOJI_COPY } from '../i18n/content';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = UI[locale];
const copy = SLACK_EMOJI_COPY[locale];
const base = import.meta.env.BASE_URL;
const url = new URL(`${base}${locale === 'en' ? '' : `${locale}/`}${SLACK_EMOJI_SLUG}`, Astro.site).href;

// 구조화 데이터 — 검색엔진이 "무료 웹 애플리케이션"으로 인식하도록.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: copy.title,
  description: copy.description,
  url,
  inLanguage: HTML_LANG[locale],
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  locale={locale}
  slug={SLACK_EMOJI_SLUG}
  jsonLd={jsonLd}
>
  <h1>{t.slackEmoji.title}</h1>
  <p class="lede">{copy.tagline}</p>

  <SlackEmoji locale={locale} />

  <style>
    h1 { margin-bottom: 0.25rem; }
    .lede { color: var(--muted); margin-top: 0; }
  </style>
</BaseLayout>
