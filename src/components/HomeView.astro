---
// 홈 화면 본문 — 로케일만 받아 기본/언어별 페이지에서 함께 재사용한다.
import BaseLayout from '../layouts/BaseLayout.astro';
import { TOOL_LIST, ANALYZE_SLUG, VIDEO_TO_WEBP_SLUG, SLACK_EMOJI_SLUG } from '../lib/formats';
import { localizedPath, type Locale } from '../i18n/config';
import { UI } from '../i18n/ui';
import { HOME_COPY, TOOL_COPY, ANALYZER_COPY, VIDEO_COPY, SLACK_EMOJI_COPY } from '../i18n/content';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = UI[locale];
const copy = HOME_COPY[locale];
const base = import.meta.env.BASE_URL;

// 카드 한 장을 표현하는 형태. icon 이 있으면 강조(featured) 카드로 렌더링한다.
type Card = {
  href: string;
  title: string;
  desc: string;
  icon?: 'search' | 'play' | 'emoji';
};

// 기능을 세 갈래로 분류한다. 도구를 추가하면 알맞은 섹션의 cards 에 한 줄만 넣으면 된다.
const sectionGroups: { title: string; cards: Card[] }[] = [
  {
    title: t.home.sections.image,
    cards: [
      {
        href: localizedPath(base, locale, ANALYZE_SLUG),
        title: t.home.analyzerCard,
        desc: ANALYZER_COPY[locale].tagline,
        icon: 'search',
      },
      ...TOOL_LIST.map((tool) => ({
        href: localizedPath(base, locale, tool.slug),
        title: t.home.cardTitle(tool.format.toUpperCase()),
        desc: TOOL_COPY[locale][tool.format].tagline,
      })),
    ],
  },
  {
    title: t.home.sections.video,
    cards: [
      {
        href: localizedPath(base, locale, VIDEO_TO_WEBP_SLUG),
        title: t.video.title,
        desc: VIDEO_COPY[locale].tagline,
        icon: 'play',
      },
    ],
  },
  {
    title: t.home.sections.other,
    cards: [
      {
        href: localizedPath(base, locale, SLACK_EMOJI_SLUG),
        title: t.slackEmoji.title,
        desc: SLACK_EMOJI_COPY[locale].tagline,
        icon: 'emoji',
      },
    ],
  },
];

// 비어 있는 섹션은 렌더링하지 않는다.
const sections = sectionGroups.filter((s) => s.cards.length > 0);
---

<BaseLayout title={copy.title} description={copy.description} locale={locale} slug="">
  {/* 화면에는 숨기되 SEO·스크린리더용 제목은 남긴다(헤더 로고와 시각적 중복만 제거). */}
  <h1 class="sr-only">{t.home.h1}</h1>
  {
    sections.map((section) => (
      <section class="tool-section">
        <h2 class="section-title">{section.title}</h2>
        <ul class="tools">
          {section.cards.map((card) => (
            <li>
              <a class={card.icon ? 'featured' : undefined} href={card.href}>
                <span class="title">
                  {card.icon === 'search' && (
                    <span class="ico" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="7" />
                        <path d="M21 21l-4.3-4.3" />
                      </svg>
                    </span>
                  )}
                  {card.icon === 'play' && (
                    <span class="ico" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2" />
                        <path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none" />
                      </svg>
                    </span>
                  )}
                  {card.icon === 'emoji' && (
                    <span class="ico" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="9" />
                        <path d="M8.5 14.5a4.5 4.5 0 0 0 7 0" />
                        <path d="M9 9.5h.01M15 9.5h.01" />
                      </svg>
                    </span>
                  )}
                  {card.title}
                </span>
                <span class="desc">{card.desc}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }

  <style>
    /* 시각적으로 숨기되 스크린리더/검색엔진에는 노출되는 제목. */
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    /* 기능 섹션 — 위에서 아래로 차례로 전개된다. */
    .tool-section { margin-top: 2.25rem; }
    .tool-section:first-of-type { margin-top: 2rem; }
    .section-title {
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      color: var(--muted); margin: 0 0 0.85rem;
    }
    .tools { list-style: none; padding: 0; display: grid; gap: 0.75rem; margin: 0; }
    .tools a {
      display: flex; flex-direction: column; gap: 0.2rem; padding: 1.1rem 1.25rem;
      background: var(--card); border: 1px solid var(--border); border-radius: 12px;
      text-decoration: none; color: var(--fg); transition: border-color 0.15s;
    }
    .tools a:hover { border-color: var(--accent); }
    .tools .title { font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
    .tools .desc { color: var(--muted); font-size: 0.9rem; }

    /* 분석기 카드 — 목록 최상단의 대표 도구라 살짝 강조한다. */
    .tools a.featured {
      background:
        radial-gradient(130% 130% at 0% 0%, rgba(110, 168, 254, 0.1), transparent 55%),
        var(--card);
      border-color: #34405a;
    }
    .tools a.featured:hover { border-color: var(--accent); }
    .tools .ico {
      display: grid; place-items: center; width: 26px; height: 26px; border-radius: 8px;
      color: var(--accent); background: rgba(110, 168, 254, 0.12);
    }
    .tools .ico svg { width: 16px; height: 16px; }
  </style>
</BaseLayout>
